// CoalWash — Antigravity (AG 2.0) hooks template.
//
// AG shipped a real IDE hook engine (hooks.json; empirical pilot 2026-07-12,
// corroborated vs the official docs 2026-07-13). This wires CoalWash's
// Phoenix-13 conductor onto AG's events via the hooks/coalwash-ag.js adapter.
// Copy this file to ONE of:
//   - project:  <workspace>/.agents/hooks.json
//   - global:   ~/.gemini/config/hooks.json      (canonical; NOT the older
//                                                  ~/.gemini/antigravity-cli/ path)
// then replace __COALWASH_DIR__ with the directory holding CoalWash's hooks/ +
// scripts/lib (a global file-copy install puts them at
// ~/.gemini/config/skills/coalwash — copy the WHOLE plugin tree: the adapter
// imports ../scripts/lib).
//
// If AG's parser rejects // comments, strip these comment lines — the object
// below is otherwise strict JSON. (Mirrors the repo's platform-configs idiom
// and CoalHearth's AG template — one flock.)
//
// Event mapping (AG has NO one-shot SessionStart — the name is valid but never
// fires; full facts + named limitations: skills/coalwash/references/platform-ag.md):
//   PreInvocation -> the SessionStart gauge, once per session (a per-session
//                    tmp marker guards against re-gauging every model call).
//   Stop          -> the band ask/directive delivery ({additionalContext}
//                    injection — an advisory degrade of CC's Stop-block).
//   PreToolUse    -> the 0p airbag (pre-edit snapshot of class-B files).
//   PostToolUse   -> the 0p seatbelt (fidelity-drop FYI advisory).
{
  "coalwash": {
    "PreInvocation": [
      { "type": "command", "command": "node \"__COALWASH_DIR__/hooks/coalwash-ag.js\" PreInvocation", "timeout": 30 }
    ],
    "Stop": [
      { "type": "command", "command": "node \"__COALWASH_DIR__/hooks/coalwash-ag.js\" Stop", "timeout": 30 }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "node \"__COALWASH_DIR__/hooks/coalwash-ag.js\" PreToolUse", "timeout": 30 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "node \"__COALWASH_DIR__/hooks/coalwash-ag.js\" PostToolUse", "timeout": 30 }
        ]
      }
    ]
  }
}
